# Kopyalayin: cp .env.example .env  (gercek sifreleri .env icine yazin; .env git'e gitmez)

# PostgreSQL (postgres + mikroservisler + Keycloak DB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=degistirin
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=9999

# Eureka — IDE: once DashboardEurekaServer (8761)
EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://127.0.0.1:8761/eureka/
EUREKA_INSTANCE_HOSTNAME=localhost
EUREKA_INSTANCE_PREFER_IP_ADDRESS=false
SPRING_CLOUD_CLIENT_IP_ADDRESS=127.0.0.1

# Keycloak — Admin Console (http://localhost:8180) ve Account Service ile ayni olmali
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=degistirin
# OAuth client secret — sql/keycloak/init-keycloak.sh (docker compose keycloak-init) ile otomatik olusturulur
# Manuel kurulum: Keycloak Admin > Clients > account-service > Direct access grants ON + secret eslestir
KEYCLOAK_CLIENT_SECRET=degistirin

# NotificationService — Gmail App Password (2FA acik; bosluklu yapistirabilirsiniz: abcd efgh ijkl mnop)
# https://myaccount.google.com/apppasswords — Google'daki gibi bosluklu yazilabilir
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_EMAIL@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
